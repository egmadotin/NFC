# Docker Compose (root)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Django
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-64-char-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOW_ALL_ORIGINS=False
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=/data/db.sqlite3
# DJANGO_REDIS_URL=redis://redis:6379/0

# Next.js (public at build-time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/nfc/

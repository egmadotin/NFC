# Django backend runtime env
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS / CSRF
DJANGO_CORS_ALLOW_ALL_ORIGINS=False
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Database: sqlite (default)
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# Database: postgres example
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=nfc
# DJANGO_DB_USER=nfc
# DJANGO_DB_PASSWORD=change-me
# DJANGO_DB_HOST=postgres
# DJANGO_DB_PORT=5432

# Optional Redis for Channels (recommended in production)
# DJANGO_REDIS_URL=redis://redis:6379/0
